    {
      "parameters": {
        "jsCode": "const districts = [\n  'quan 1', 'quan 3', 'quan 4', 'quan 5', 'quan 6', 'quan 7', 'quan 8',\n  'quan 10', 'quan 11', 'quan 12', 'binh thanh', 'tan binh', 'tan phu',\n  'phu nhuan', 'go vap', 'thu duc', 'binh tan', 'nha be', 'hoc mon', 'cu chi'\n];\n\nconst maxPages = 3;\nconst includeRawJson = false;\nconst includeMetaJson = false;\n\nconst rows = [];\nfor (const district of districts) {\n  const query = ('rua xe oto ' + district + ' ho chi minh').replace(/\\s+/g, ' ').trim();\n  for (let i = 0; i < maxPages; i += 1) {\n    rows.push({\n      json: {\n        district,\n        query,\n        start: i * 20,\n        page: i + 1,\n        max_pages: maxPages,\n        include_raw_json: includeRawJson,\n        include_meta_json: includeMetaJson\n      }\n    });\n  }\n}\n\nreturn rows;"
      },
      "id": "3d2212ec-a4df-434e-b56e-dbd4c9717c74",
      "name": "Build Search Pages",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        976,
        976
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst out = [];\nconst seen = new Set();\nconst slugCache = new Map();\nconst crawledAt = new Date().toISOString();\n\nconst districtRegex = /(quan\\s*\\d+|thu duc|binh thanh|tan binh|tan phu|phu nhuan|go vap|binh tan|nha be|hoc mon|cu chi)/i;\n\nconst slug = (text) => {\n  const source = String(text || '');\n  if (slugCache.has(source)) return slugCache.get(source);\n\n  const value = source\n    .toLowerCase()\n    .normalize('NFD')\n    .replace(/[\\u0300-\\u036f]/g, '')\n    .replace(/[^a-z0-9]+/g, '_')\n    .replace(/^_+|_+$/g, '') || 'na';\n\n  slugCache.set(source, value);\n  return value;\n};\n\nfor (let i = 0; i < items.length; i += 1) {\n  const payload = items[i].json || {};\n  const results = payload.local_results;\n  if (!Array.isArray(results) || results.length === 0) continue;\n\n  const includeRawJson = payload.include_raw_json === true;\n  const includeMetaJson = payload.include_meta_json === true;\n\n  const metadata = payload.search_metadata || {};\n  const params = payload.search_parameters || {};\n  const info = payload.search_information || {};\n  const query = info.query_displayed || params.q || '';\n\n  const normalizedQuery = query.toLowerCase().normalize('NFD').replace(/[\\u0300-\\u036f]/g, '');\n  const districtMatch = normalizedQuery.match(districtRegex);\n  const district = districtMatch ? districtMatch[0].trim() : 'toan_thanh_pho';\n  const districtKey = slug(district);\n  const pageStart = Number(params.start || 0);\n\n  for (let index = 0; index < results.length; index += 1) {\n    const place = results[index] || {};\n    const placeId = place.place_id || '';\n    const title = place.title || 'N/A';\n    const address = place.address || 'N/A';\n    const absolutePosition = pageStart + index + 1;\n\n    const fallbackIdentity = slug(title) + '_' + slug(address) + '_' + districtKey;\n    const recordKey = placeId || fallbackIdentity;\n\n    if (seen.has(recordKey)) continue;\n    seen.add(recordKey);\n\n    const coords = place.gps_coordinates || {};\n    const operatingHours = place.operating_hours || {};\n    const serviceOptions = place.service_options || {};\n\n    const fridayPair = Object.entries(operatingHours).find(([k]) => {\n      const key = slug(k);\n      return key.includes('thu_sau') || key.includes('friday');\n    });\n    const fridayHours = fridayPair ? fridayPair[1] : 'N/A';\n\n    let onSite = null;\n    for (const [k, v] of Object.entries(serviceOptions)) {\n      const key = slug(k);\n      if (key.includes('tai_cho') || key.includes('on_site')) { onSite = v; break; }\n    }\n\n    out.push({\n      json: {\n        record_key: recordKey,\n        district,\n        page_start: pageStart,\n        page_position: Number(place.position || index + 1),\n        position: absolutePosition,\n        title,\n        type: place.type || 'N/A',\n        type_id: place.type_id || '',\n        type_ids: (place.type_ids || []).join(', '),\n        types: (place.types || []).join(', '),\n\n        address,\n        phone: place.phone ? (\"'\" + place.phone) : 'N/A',\n        website: place.website || 'N/A',\n        latitude: coords.latitude ?? null,\n        longitude: coords.longitude ?? null,\n\n        rating: Number(place.rating || 0),\n        reviews: Number(place.reviews || 0),\n        price: place.price || 'N/A',\n\n        open_state: place.open_state || 'N/A',\n        hours: place.hours || place.open_state || 'N/A',\n        friday_hours: fridayHours,\n\n        place_id: placeId,\n        provider_id: place.provider_id || '',\n        data_id: place.data_id || '',\n        data_cid: place.data_cid || '',\n        place_link: place.place_id_search || '',\n        reviews_link: place.reviews_link || '',\n        photos_link: place.photos_link || '',\n        thumbnail: place.thumbnail || '',\n        serpapi_thumbnail: place.serpapi_thumbnail || '',\n\n        unclaimed_listing: Boolean(place.unclaimed_listing),\n        service_options_on_site: onSite,\n\n        query,\n        local_results_state: info.local_results_state || '',\n        search_id: metadata.id || '',\n        google_maps_url: metadata.google_maps_url || '',\n        json_endpoint: metadata.json_endpoint || '',\n        hl: params.hl || '',\n        gl: params.gl || '',\n\n        operating_hours_json: includeMetaJson ? JSON.stringify(operatingHours) : '',\n        service_options_json: includeMetaJson ? JSON.stringify(serviceOptions) : '',\n        raw_place_json: includeRawJson ? JSON.stringify(place) : '',\n\n        crawl_date: crawledAt\n      }\n    });\n  }\n}\n\nreturn out;"
      },
