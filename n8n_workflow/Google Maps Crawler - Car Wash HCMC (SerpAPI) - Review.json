    {
      "parameters": {
        "jsCode": "// Collect all incoming node items, then normalize to an array of place responses.\nconst inputItems = $input.all();\nconst allResponses = [];\n\nfor (const item of inputItems) {\n  const payload = item.json;\n  if (Array.isArray(payload)) {\n    allResponses.push(...payload);\n  } else if (payload && typeof payload === 'object') {\n    allResponses.push(payload);\n  }\n}\n\nconst allReviews = [];\nconst crawlTimestamp = new Date().toISOString();\nconst crawlDate = crawlTimestamp.split('T')[0];\n\nallResponses.forEach((response) => {\n  const placeInfo = response.place_info || {};\n  const placeId = response.search_parameters?.place_id || placeInfo.place_id || '';\n  const placeName = placeInfo.title || '';\n  const placeAddress = placeInfo.address || '';\n  const placeRating = Number(placeInfo.rating || 0);\n  const placeType = placeInfo.type || '';\n\n  const reviews = Array.isArray(response.reviews) ? response.reviews : [];\n\n  reviews.forEach((review, index) => {\n    const user = review.user || {};\n    const extractedSnippet = review.extracted_snippet || {};\n    const images = Array.isArray(review.images) ? review.images : [];\n    const reviewId = review.review_id || `${placeId}_rev_${index}_${Date.now()}`;\n\n    allReviews.push({\n      review_id: reviewId,\n      record_key: placeId,\n      place_id: placeId,\n      place_name: placeName,\n      place_address: placeAddress,\n      place_rating: placeRating,\n      place_type: placeType,\n      reviewer_name: user.name || 'Anonymous',\n      reviewer_id: user.contributor_id || '',\n      reviewer_is_local_guide: user.local_guide === true ? 'Yes' : 'No',\n      reviewer_review_count: Number(user.reviews || 0),\n      reviewer_photo_count: Number(user.photos || 0),\n      rating: Number(review.rating || 0),\n      review_text: (extractedSnippet.original || review.snippet || '').substring(0, 5000),\n      review_text_translated: (extractedSnippet.translated || '').substring(0, 5000),\n      review_date: review.iso_date || review.date || '',\n      review_position: Number(review.position || 0),\n      likes: Number(review.likes || 0),\n      images_count: images.length,\n      images_json: images.length ? JSON.stringify(images) : '',\n      review_link: review.link || '',\n      source: review.source || 'Google',\n      crawl_date: crawlDate,\n      crawl_timestamp: crawlTimestamp\n    });\n  });\n});\n\nreturn allReviews;"
      },
