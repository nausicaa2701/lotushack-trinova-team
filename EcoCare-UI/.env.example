# Public app config (embedded in the client bundle at build time).
# Never put secrets, API keys, or tokens in VITE_* — they are visible in shipped JS.
#
# API base: use the same host/port as FastAPI (e.g. http://127.0.0.1:8000). Wrong port = empty data / failed fetches.
# Use origin only: `http://127.0.0.1:8000` (do not append `/api`; request paths already include `/api/...`).
# Leave empty in dev to use Vite's proxy (vite.config.ts forwards /api → http://127.0.0.1:8000).
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_VOICE_SEARCH_API_BASE_URL=

# Dev/preview only: used by the Vite voice-search proxy middleware (not bundled into the app).
ELEVENLABS_API_KEY=
