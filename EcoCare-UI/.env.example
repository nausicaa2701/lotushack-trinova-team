# Public app config (embedded in the client bundle at build time).
# Never put secrets, API keys, or tokens in VITE_* — they are visible in shipped JS.
VITE_API_BASE_URL=http://localhost:4000
VITE_VOICE_SEARCH_API_BASE_URL=

# Dev/preview only: used by the Vite voice-search proxy middleware (not bundled into the app).
ELEVENLABS_API_KEY=
